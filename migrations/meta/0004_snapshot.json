  "views": {
    "public.lesson_stats": {
      "columns": {
        "category": {
          "name": "category",
          "type": "text",
          "primaryKey": false,
          "notNull": false
        },
        "level": {
          "name": "level",
          "type": "text",
          "primaryKey": false,
          "notNull": false
        },
        "lesson_count": {
          "name": "lesson_count",
          "type": "integer",
          "primaryKey": false,
          "notNull": false
        },
        "exercise_count": {
          "name": "exercise_count",
          "type": "integer",
          "primaryKey": false,
          "notNull": false
        },
        "last_refreshed": {
          "name": "last_refreshed",
          "type": "timestamp",
          "primaryKey": false,
          "notNull": false
        }
      },
      "definition": "\n  SELECT\n    l.category,\n    l.level,\n    COUNT(DISTINCT l.id)::int AS lesson_count,\n    COUNT(e.id)::int          AS exercise_count,\n    NOW()                     AS last_refreshed\n  FROM lessons l\n  LEFT JOIN exercises e ON e.lesson_id = l.id\n  GROUP BY l.category, l.level\n",
      "name": "lesson_stats",
      "schema": "public",
      "isExisting": false,
      "materialized": true
    }
  },
